    <owl:imports rdf:resource="https://w3id.org/ontostart/pro"/>
    <owl:imports rdf:resource="https://w3id.org/sulo"/>
    <owl:priorVersion rdf:resource="https://w3id.org/ontostart/pizza/0.0.10"/>
    <owl:versionIRI rdf:resource="https://w3id.org/ontostart/pizza/0.0.11"/>
