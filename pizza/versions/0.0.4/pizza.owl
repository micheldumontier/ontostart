  <rdf:Description rdf:about="https://w3id.org/ontostart/pizza/">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Ontology"/>
    <rdfs:label xml:lang="en">SULO Pizza Tutorial Ontology</rdfs:label>
    <dc:creator rdf:resource="https://orcid.org/0000-0003-4727-9435"/>
    <dcterms:alternative xml:lang="en">pizza</dcterms:alternative>
    <dcterms:bibliographicCitation xml:lang="en">Unpublished</dcterms:bibliographicCitation>
    <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-4727-9435"/>
    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-09T07:24:20.644617+00:00</dcterms:created>
    <dcterms:description xml:lang="en">An OWL ontology for the pizza domain, built incrementally through the SULO Pizza Tutorial. Covers spatial composition, qualities, quantities, processes, time, and spatial containment.</dcterms:description>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-09</dcterms:issued>
    <dcterms:language rdf:resource="http://lexvo.org/id/iso639-1/en"/>
    <dcterms:license rdf:resource="https://creativecommons.org/licenses/by/4.0/"/>
    <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-09T07:24:20.644617+00:00</dcterms:modified>
    <dcterms:publisher rdf:resource="https://github.com/micheldumontier"/>
    <dcterms:title xml:lang="en">SULO Pizza Tutorial Ontology</dcterms:title>
    <pav:authoredBy rdf:resource="https://orcid.org/0000-0003-4727-9435"/>
    <vann:preferredNamespacePrefix>pizza</vann:preferredNamespacePrefix>
    <vann:preferredNamespaceUri rdf:resource="https://w3id.org/ontostart/pizza/"/>
    <rdfs:comment xml:lang="en">An OWL ontology for the pizza domain, built incrementally through the SULO Pizza Tutorial. Covers spatial composition, qualities, quantities, processes, time, and spatial containment.</rdfs:comment>
    <owl:imports rdf:resource="https://w3id.org/ontostart/pro"/>
    <owl:imports rdf:resource="https://w3id.org/sulo"/>
    <owl:versionIRI rdf:resource="https://w3id.org/ontostart/pizza/0.0.4"/>
    <owl:versionInfo rdf:datatype="http://www.w3.org/2001/XMLSchema#string">0.0.4</owl:versionInfo>
    <dcat:accessURL rdf:resource="https://w3id.org/ontostart/pizza/"/>
    <foaf:homepage rdf:resource="https://github.com/micheldumontier/ontostart"/>
    <schema:funding xml:lang="en">This work is supported by the SULO Pizza Tutorial at ESWC 2026.</schema:funding>
    <mod:definitionProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#comment"/>
    <mod:hasRepresentationLanguage rdf:resource="http://omv.ontoware.org/2005/05/ontology#OWL"/>
