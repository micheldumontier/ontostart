    <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-19T07:37:38.845348+00:00</dcterms:created>
    <dcterms:description rdf:datatype="http://www.w3.org/2001/XMLSchema#string">An OWL ontology for the pizza domain, built incrementally through the SULO Pizza Tutorial. Covers spatial composition, qualities, quantities, processes, information entities, time, and spatial containment.</dcterms:description>
    <dcterms:issued rdf:datatype="http://www.w3.org/2001/XMLSchema#date">2026-05-19</dcterms:issued>
    <dcterms:language rdf:datatype="http://www.w3.org/2001/XMLSchema#string">http://lexvo.org/id/iso639-1/en</dcterms:language>
