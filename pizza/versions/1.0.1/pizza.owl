    <dcterms:modified rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2026-05-19T07:37:38.845348+00:00</dcterms:modified>
    <dcterms:publisher rdf:datatype="http://www.w3.org/2001/XMLSchema#string">https://github.com/micheldumontier</dcterms:publisher>
    <dcterms:title rdf:datatype="http://www.w3.org/2001/XMLSchema#string">SULO Pizza Tutorial Ontology</dcterms:title>
