    "http://purl.org/dc/terms/description": [
      {
        "@language": "en",
        "@value": "An OWL ontology for the pizza domain, built incrementally through the SULO Pizza Tutorial. Covers spatial composition, qualities, quantities, processes, time, and spatial containment. Built for ESWC 2026."
