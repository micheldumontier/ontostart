    "http://purl.org/dc/terms/description": [
      {
        "@type": "http://www.w3.org/2001/XMLSchema#string",
        "@value": "A small SULO extension that defines reusable subclasses of sulo:Role (agent, patient, instrument, location, etc.) and sulo:Process (transformation, developmental, ...). PRO is intended to be imported by domain ontologies that need a finer-grained vocabulary for describing process participants."
      }
    ],
