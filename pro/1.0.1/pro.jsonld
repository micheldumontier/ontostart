          }
        ]
      }
    ]
  },
  {
    "@id": "https://w3id.org/ontostart/pro/DevelopmentalProcess",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A process in which a participant undergoes ordered internal change toward a mature state."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "developmental process"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/sulo/Process"
      }
    ],
    "http://www.w3.org/2002/07/owl#disjointWith": [
      {
        "@id": "https://w3id.org/ontostart/pro/TransformationProcess"
      }
    ]
  },
  {
    "@id": "https://w3id.org/ontostart/pro/DevelopmentRole",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A patient role in which the entity undergoes ordered, internally driven change toward a mature state (e.g. growth, maturation)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "development role"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/ontostart/pro/PatientRole"
      }
    ]
  },
  {
    "@id": "https://w3id.org/ontostart/pro/ContainmentRole",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "containment role"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/ontostart/pro/LocationRole"
      }
    ]
  },
