            "@id": "https://w3id.org/ontostart/pro/PersistingRole"
          },
          {
            "@id": "https://w3id.org/ontostart/pro/EmergingRole"
          }
        ]
      }
    ]
  },
  {
    "@id": "https://w3id.org/ontostart/pro/ContainedRole",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "contained role"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/ontostart/pro/LocationRole"
      }
    ]
  },
  {
    "@id": "https://w3id.org/ontostart/pro/PersistingRole",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A role borne by an entity that continues to exist, in essentially the same form, throughout the process."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "persisting role"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/sulo/Role"
      }
    ]
  },
  {
    "@id": "https://w3id.org/ontostart/pro/LocationRole",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A role borne by an entity that serves as the spatial setting in which a process occurs."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "location role"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/sulo/Role"
      }
    ]
  },
  {
    "@id": "http://purl.org/dc/terms/description",
    "@type": [
