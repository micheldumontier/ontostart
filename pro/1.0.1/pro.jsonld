[
  {
    "@id": "https://w3id.org/ontostart/pro/InstrumentRole",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A role borne by an entity that is used by an agent to bring about a change during a process, without itself being changed."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "instrument role"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/sulo/Role"
      }
    ]
  },
  {
    "@id": "https://w3id.org/ontostart/pro/ConsumedRole",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A patient role in which the entity is incorporated into, or destroyed by, the process (e.g. an ingredient that is mixed into a dough)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "consumed role"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/ontostart/pro/PatientRole"
      }
    ]
  },
  {
    "@id": "https://w3id.org/ontostart/pro/AgentRole",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A role borne by an entity that actively brings about a change during a process."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "agent role"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/sulo/Role"
      }
    ]
  },
  {
    "@id": "https://w3id.org/ontostart/pro/SurfacePositionRole",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "surface position role"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/ontostart/pro/LocationRole"
      }
    ]
  },
  {
    "@id": "https://w3id.org/ontostart/pro/PatientRole",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A role borne by an entity that undergoes a change as a result of a process."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "patient role"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/sulo/Role"
      }
    ]
  },
  {
    "@id": "https://w3id.org/ontostart/pro/TransformationProcess",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A process in which one or more participants change their qualities, composition, or identity (e.g. baking, cooking)."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "transformation process"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/sulo/Process"
      }
    ]
  },
  {
    "@id": "https://w3id.org/ontostart/pro/EmergingRole",
    "@type": [
      "http://www.w3.org/2002/07/owl#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A role borne by an entity that comes into existence as an outcome of the process."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#label": [
      {
        "@language": "en",
        "@value": "emerging role"
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#subClassOf": [
      {
        "@id": "https://w3id.org/sulo/Role"
      }
    ]
  },
  {
    "@id": "_:n2dae7800efde462e916f6301ae24d498b1",
    "@type": [
      "http://www.w3.org/2002/07/owl#AllDisjointClasses"
    ],
