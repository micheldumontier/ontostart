  <rdf:Description rdf:about="https://w3id.org/ontostart/pizza/ScovilleHeatUnit">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#Class"/>
    <rdfs:comment rdf:datatype="http://www.w3.org/2001/XMLSchema#string">A unit to measure the spiciness or "heat" of chili peppers and substances based on their concentration of capsaicinoids. 
                    The scale indicates how many times a chili extract must be diluted in sugar water before its heat is undetectable to tasters.</rdfs:comment>
    <rdfs:subClassOf rdf:resource="https://w3id.org/sulo/Unit"/>
  </rdf:Description>
